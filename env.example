# Weir Proxy
# Your personal API key (shown in the Weir dashboard after sign-up)
WEIR_API_KEY=wk_your_key_here

# URL of the Weir dashboard — use localhost for local dev, real URL in prod
WEIR_DASHBOARD_URL=http://localhost:8000

# Database to protect
WEIR_TARGET_HOST=localhost
WEIR_TARGET_PORT=5432
WEIR_TARGET_DB=postgres
WEIR_TARGET_USER=postgres
WEIR_TARGET_PASSWORD=

# Proxy listen port
WEIR_LISTEN_HOST=0.0.0.0
WEIR_LISTEN_PORT=5433

# Supabase (dashboard + proxy internal use)
WEIR_SUPABASE_URL=https://your-project.supabase.co
# service_role key — never expose this to users
WEIR_SERVICE_KEY=your_service_role_key_here

# Dashboard
# anon key — used only to send magic link emails
WEIR_SUPABASE_KEY=your_anon_key_here
# Random 32-byte hex string: python -c "import secrets; print(secrets.token_hex(32))"
WEIR_SECRET_KEY=generate_with_secrets_token_hex_32
WEIR_ENV=development

# Approval timeout
WEIR_APPROVAL_TIMEOUT=60
